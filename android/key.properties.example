## Template — copier ce fichier en key.properties et renseigner les valeurs.
## Ne jamais committer key.properties (déjà dans .gitignore).
##
## Pour générer le keystore :
##   keytool -genkey -v -keystore ~/akom_release.jks \
##           -keyalg RSA -keysize 2048 -validity 10000 \
##           -alias akom_release

storePassword=VOTRE_MOT_DE_PASSE_KEYSTORE
keyPassword=VOTRE_MOT_DE_PASSE_CLE
keyAlias=akom_release
storeFile=/chemin/absolu/vers/akom_release.jks
